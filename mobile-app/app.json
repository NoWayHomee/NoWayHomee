{
  "expo": {
    "name": "NoWayHome",
    "slug": "nowayhome-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nowayhome",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nowayhome.app"
    },
    "splash": {
      "image": "./assets/images/logo3.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#f4f4e8"
    },
    "android": {
      "package": "com.nowayhome.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#003580"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo3.jpg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f4f4e8"
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
