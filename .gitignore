# =============================================================================
dist/
build/
out/

# =============================================================================
# Environment files
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
Desktop.ini

# =============================================================================
# Editor / IDE
# =============================================================================
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# =============================================================================
# Vite / Turbo cache
# =============================================================================
.vite/
**/.vite/
.turbo/

# =============================================================================
# TypeScript
# =============================================================================
*.tsbuildinfo

# =============================================================================
# Backend (NestJS)
# =============================================================================
# Uploaded files (if stored locally)
uploads/
**/uploads/

# Scratch / one-off scripts at root and backend
scratch_*.js
backend/scratch_*.js

# Prisma generated client (rebuilt on install)
**/generated/prisma/

# =============================================================================
# Web (Vite / React)
# =============================================================================
web/**/dist/

# =============================================================================
# Mobile (Expo / React Native)
# =============================================================================
mobile-app/.expo/*
!mobile-app/.expo/types/
!mobile-app/.expo/types/router.d.ts

mobile-app/expo-env.d.ts
mobile-app/web-build/
mobile-app/.metro-health-check*
mobile-app/*.orig.*

# iOS / Android native folders (generated by Expo prebuild)
mobile-app/ios/
mobile-app/android/
mobile-app/.kotlin/

# Signing / cert files
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# =============================================================================
# Database snapshots (auto-generated, not source-controlled)
# =============================================================================
!database/snapshots/data.sql
!database/snapshots/schema.sql

# =============================================================================
# Python (database tooling)
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# =============================================================================
